PORT=5000
ALLOWED_ORIGINS=https://adco-submit.vercel.app,http://localhost:5173,http://localhost:3000

# MongoDB
# Use your DigitalOcean managed MongoDB connection string here.
MONGODB_URI=

# DigitalOcean Spaces
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_REGION=sfo3
SPACES_BUCKET=u-storage
SPACES_KEY=
SPACES_SECRET=
SPACES_FORCE_PATH_STYLE=false

# Backward-compatible aliases if you prefer the existing names:
# MONGO_URI=
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_KEY=
# S3_SECRET=
