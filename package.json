{
  "name": "e-agenda",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "prebuild": "npm run docs:generate",
    "build": "npm --prefix frontend install --include=dev && npm --prefix frontend run build",
    "start": "npm --prefix backend start",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:watch": "node scripts/generate-docs.js --watch"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "multer": "^2.1.1",
    "xlsx": "^0.18.5"
  }
}
